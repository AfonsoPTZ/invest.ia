{
  "name": "invest-ia",
  "version": "1.0.0",
  "description": "Investment Intelligence Application - Full stack application with React frontend and Express backend",
  "private": true,
  "author": {
    "name": "Afonso Braga Plentz",
    "email": "afonsobplentz@gmail.com"
  },
  "repository": {
    "type": "git",
