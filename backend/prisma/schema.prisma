// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USERS TABLE
// ============================================
model User {
  id              Int                    @id @default(autoincrement())
  name            String                 @db.VarChar(150)
  email           String                 @unique @db.VarChar(150)
  cpf             String                 @unique @db.Char(11)
  phone           String                 @unique @db.VarChar(20)
  passwordHash    String                 @map("password_hash") @db.VarChar(255)
  emailVerified   Boolean                @default(false) @map("email_verified")
  otpCodeHash     String?                @map("otp_code_hash") @db.VarChar(255)
  otpExpiresAt    DateTime?              @map("otp_expires_at")
  otpAttempts     Int                    @default(0) @map("otp_attempts")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  // Relations
  financialProfile FinancialProfile?
  earnings        Earning[]
  expenses        Expense[]
  investments     Investment[]
  assets          Asset[]
  financialGoals  FinancialGoal[]
  monthlySummaries MonthlySummary[]

  @@map("users")
}

// ============================================
// 2. FINANCIAL PROFILES TABLE
// ============================================
model FinancialProfile {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique @map("user_id")
  monthlyIncome    Decimal   @default(0.00) @map("monthly_income") @db.Decimal(12, 2)
  initialBalance   Decimal   @default(0.00) @map("initial_balance") @db.Decimal(12, 2)
  hasInvestments   Boolean   @default(false) @map("has_investments")
  hasAssets        Boolean   @default(false) @map("has_assets")
  financialGoal    String    @map("financial_goal") @db.VarChar(255)
  behaviorProfile  String    @default("moderate") @map("behavior_profile") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_profiles")
}

// ============================================
// 3. EARNINGS TABLE
// ============================================
model Earning {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  description String    @db.VarChar(255)
  amount      Decimal   @db.Decimal(12, 2)
  earnedDate  DateTime  @map("earned_date") @db.Date
  isFixed     Boolean   @default(false) @map("is_fixed")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("earnings")
}

// ============================================
// 4. EXPENSES TABLE
// ============================================
model Expense {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  description String    @db.VarChar(255)
  amount      Decimal   @db.Decimal(12, 2)
  expenseDate DateTime  @map("expense_date") @db.Date
  isFixed     Boolean   @default(false) @map("is_fixed")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ============================================
// 5. INVESTMENTS TABLE
// ============================================
model Investment {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  investmentType   String    @map("investment_type") @db.VarChar(100)
  assetName        String    @map("asset_name") @db.VarChar(150)
  investedAmount   Decimal   @map("invested_amount") @db.Decimal(12, 2)
  currentAmount    Decimal?  @map("current_amount") @db.Decimal(12, 2)
  riskLevel        String    @default("medium") @map("risk_level") @db.VarChar(50)
  investmentDate   DateTime? @map("investment_date") @db.Date
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investments")
}

// ============================================
// 6. ASSETS TABLE
// ============================================
model Asset {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  assetType        String    @map("asset_type") @db.VarChar(100)
  description      String    @db.VarChar(255)
  estimatedValue   Decimal   @map("estimated_value") @db.Decimal(12, 2)
  acquisitionDate  DateTime? @map("acquisition_date") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assets")
}

// ============================================
// 7. FINANCIAL GOALS TABLE
// ============================================
model FinancialGoal {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  title           String    @db.VarChar(150)
  description     String?   @db.Text
  targetAmount    Decimal   @map("target_amount") @db.Decimal(12, 2)
  targetDate      DateTime? @map("target_date") @db.Date
  currentAmount   Decimal   @default(0.00) @map("current_amount") @db.Decimal(12, 2)
  status          String    @default("not_started") @map("status") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_goals")
}

// ============================================
// 8. MONTHLY SUMMARIES TABLE
// ============================================
model MonthlySummary {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  year             Int
  month            Int
  totalEarnings    Decimal   @default(0.00) @map("total_earnings") @db.Decimal(12, 2)
  totalExpenses    Decimal   @default(0.00) @map("total_expenses") @db.Decimal(12, 2)
  beginningBalance Decimal   @default(0.00) @map("beginning_balance") @db.Decimal(12, 2)
  endingBalance    Decimal   @default(0.00) @map("ending_balance") @db.Decimal(12, 2)
  savingsAmount    Decimal   @default(0.00) @map("savings_amount") @db.Decimal(12, 2)
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month], name: "uq_summary_user_month")
  @@map("monthly_summaries")
}
